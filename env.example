# ==========================================
# TAZDAYTH - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy this file to .env and fill in the values.
# DO NOT COMMIT THE REAL .env FILE!

# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=production
ALLOWED_ORIGIN=https://votre-site.com

# --- DATABASE ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tazdayth?retryWrites=true&w=majority

# --- SECURITY ---
# Generate a long random string (e.g. 64 characters)
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire

# --- GOOGLE AUTHENTICATION ---
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=votre_client_id_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre_client_secret_google

# --- EMAIL CONFIGURATION (SMTP) ---
# For a real customer, use Gmail, Outlook or SendGrid
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=contact@tazdayth.com
EMAIL_PASS=votre_mot_de_passe_app_email

# --- FRONTEND ASSETS ---
# In production, this might be needed for absolute paths
VITE_API_URL=https://votre-api.com/api
VITE_GOOGLE_CLIENT_ID=votre_client_id_google.apps.googleusercontent.com
